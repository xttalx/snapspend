# SnapSpend uses Vite + Express (not Next.js). Same Supabase keys, different names.
# Copy to .env and fill in values from Supabase → Project Settings → API

# ─── Server (API on Vercel / local port 3456) ───
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ─── Browser sign-in (pick one key style) ───
# Recommended from Supabase dashboard (publishable):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Or legacy anon JWT (eyJ…, role anon) if publishable fails:
# SUPABASE_ANON_KEY=eyJ...

# Vite aliases (optional, same values):
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_... or eyJ...

# ─── Auth ───
JWT_SECRET=generate-a-long-random-string
JWT_EXPIRES_IN=30d

# ─── App URLs ───
FRONTEND_URL=https://your-app.vercel.app
CORS_ORIGIN=https://your-app.vercel.app
VITE_API_URL=

# ─── AI (Snap chat) ───
ANTHROPIC_API_KEY=

MILE_RATE=0.67
PORT=3456
