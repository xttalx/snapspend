# ─── Supabase (Dashboard → Project Settings → API) ───
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Aliases also work on Vercel: SUPABASE_SECRET_KEY, REACT_APP_SUPABASE_URL
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Alias: REACT_APP_SUPABASE_PUBLISHABLE_KEY

# ─── Auth (Supabase Auth — Google + email/password) ───
# In Supabase Dashboard → Authentication → Providers: enable Email + Google
# Redirect URLs: http://localhost:5173, https://your-app.vercel.app
JWT_SECRET=generate-a-long-random-string
JWT_EXPIRES_IN=30d

# ─── App URLs (Vercel sets VERCEL_URL automatically) ───
FRONTEND_URL=https://your-app.vercel.app
CORS_ORIGIN=https://your-app.vercel.app
# Local Vite only — leave empty to use same-origin / proxy
VITE_API_URL=

# ─── AI (Snap chat) ───
ANTHROPIC_API_KEY=
# Optional model override (default: claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=

MILE_RATE=0.67
PORT=3456
